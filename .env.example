# AdSense publisher ID (used by both AdSense and Funding Choices).
# Format: ca-pub-XXXXXXXXXXXXXXXX (16 digits)
# Leave empty in dev to render ad placeholders instead of real ads.
PUBLIC_ADSENSE_CLIENT=

# GA4 Measurement ID. Format: G-XXXXXXXXXX
PUBLIC_GA4_ID=

# Site canonical URL (used in some helpers; astro.config.mjs has the build-time value)
PUBLIC_SITE_URL=https://factu.guide
