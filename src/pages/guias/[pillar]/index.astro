---
import { getCollection } from 'astro:content';
import Container from '../../../components/layout/Container.astro';
import BaseLayout from '../../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const PILLARS = ['cumplimiento', 'fiscalidad', 'casos'] as const;
  return PILLARS.map((p) => ({ params: { pillar: p } }));
}

const { pillar } = Astro.params as { pillar: 'cumplimiento' | 'fiscalidad' | 'casos' };

const labels: Record<typeof pillar, string> = {
  cumplimiento: 'Cumplimiento VeriFactu',
  fiscalidad: 'Fundamentos fiscales',
  casos: 'Casos prácticos por sector',
};
const descriptions: Record<typeof pillar, string> = {
  cumplimiento: 'Plazos AEAT, sanciones, anulaciones, encadenamiento SHA-256. Lo que necesitas saber para cumplir sin sustos.',
  fiscalidad: 'IVA 21/10/4, retención IRPF, modelos 130, 303 y 390, NIF intracomunitario. La fiscalidad práctica del autónomo.',
  casos: 'Cómo factura un dev freelance, un restaurante, un e-commerce, un profesional sanitario. Ejemplos reales por sector.',
};
const accents: Record<typeof pillar, string> = {
  cumplimiento: 'bg-brand-100 text-brand-700',
  fiscalidad: 'bg-amber-100 text-amber-700',
  casos: 'bg-green-100 text-green-700',
};
const icons: Record<typeof pillar, string> = {
  cumplimiento: '⚖️',
  fiscalidad: '📊',
  casos: '🎯',
};

const articles = (
  await getCollection('blog', (e) => !e.data.draft && e.data.pillar === pillar)
).sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
---
<BaseLayout
  title={`${labels[pillar]} | factu.guide`}
  description={descriptions[pillar]}
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-50 via-white to-brand-50/30 py-16 md:py-20">
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(37,99,235,0.18)_1px,transparent_0)] [background-size:24px_24px] [mask-image:radial-gradient(ellipse_at_center,black,transparent_75%)]"
      aria-hidden="true"
    ></div>
    <Container>
      <div class="relative max-w-3xl mx-auto text-center">
        <nav class="font-sans text-xs text-ink-subtle mb-6" aria-label="Breadcrumb">
          <a href="/guias" class="hover:text-ink">Guías</a> ›
          <span class="text-ink-muted">{labels[pillar]}</span>
        </nav>
        <div class={`inline-flex h-14 w-14 rounded-2xl ${accents[pillar]} items-center justify-center text-3xl mb-5`}>
          {icons[pillar]}
        </div>
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-ink leading-[1.1] tracking-tight">
          {labels[pillar]}
        </h1>
        <p class="mt-5 text-lg text-ink-muted leading-relaxed">{descriptions[pillar]}</p>
      </div>
    </Container>
  </section>

  <!-- Articles list -->
  <section class="py-16 md:py-20">
    <Container>
      {articles.length > 0 ? (
        <ul class="grid gap-6 md:grid-cols-2 max-w-5xl mx-auto">
          {articles.map(a => (
            <li>
              <a
                href={`/guias/${a.id}`}
                class="group flex h-full flex-col rounded-2xl border border-zinc-200 bg-white p-7 hover:shadow-xl hover:-translate-y-1 hover:border-brand-300 transition-all duration-200"
              >
                <h2 class="font-serif text-xl font-bold text-ink leading-snug mb-3 group-hover:text-brand-900 transition">
                  {a.data.title}
                </h2>
                <p class="text-sm text-ink-muted leading-relaxed mb-4 line-clamp-3">{a.data.description}</p>
                <div class="mt-auto flex items-center justify-between text-xs text-ink-subtle pt-4 border-t border-zinc-100">
                  <span>
                    {a.data.publishedAt.toLocaleDateString('es-ES', {
                      year: 'numeric',
                      month: 'short',
                      day: 'numeric',
                    })} · {a.data.readingTime} min
                  </span>
                  <span class="text-brand-700 font-semibold inline-flex items-center gap-0.5 group-hover:gap-1 transition-all">
                    Leer
                    <span>→</span>
                  </span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      ) : (
        <p class="text-center text-ink-subtle py-16">Aún no hay guías en este pilar.</p>
      )}
    </Container>
  </section>
</BaseLayout>
