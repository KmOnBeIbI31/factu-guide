---
import { getCollection } from 'astro:content';
import Container from '../../components/layout/Container.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const PILLARS = [
  {
    slug: 'cumplimiento',
    title: 'Cumplimiento VeriFactu',
    desc: 'Plazos AEAT, sanciones, requisitos técnicos, FAQ.',
  },
  {
    slug: 'fiscalidad',
    title: 'Fundamentos fiscales',
    desc: 'IVA, IRPF, modelos 130/303/390, NIF/CIF.',
  },
  {
    slug: 'casos',
    title: 'Casos por sector',
    desc: 'Dev freelance, restaurante, e-commerce, profesional sanitario.',
  },
];

const all = (await getCollection('blog', (e) => !e.data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 9);
---
<BaseLayout
  title="Guías VeriFactu y facturación para autónomos | factu.guide"
  description="Guías prácticas sobre VeriFactu, IVA, IRPF y casos reales por sector. Para autónomos y gestorías."
>
  <Container>
    <section class="py-12">
      <h1 class="text-4xl font-bold text-ink">Guías</h1>
      <p class="mt-3 text-lg text-ink-muted">Cumplimiento, fiscalidad y casos por sector.</p>

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {PILLARS.map(p => (
          <a
            href={`/guias/${p.slug}`}
            class="block rounded-xl border border-zinc-200 bg-white p-5 shadow-card hover:border-brand-500 transition"
          >
            <h2 class="font-semibold text-ink">{p.title}</h2>
            <p class="mt-2 text-sm text-ink-muted">{p.desc}</p>
          </a>
        ))}
      </div>

      {all.length > 0 && (
        <>
          <h2 class="mt-12 text-2xl font-bold text-ink">Últimas guías</h2>
          <ul class="mt-4 divide-y divide-zinc-200">
            {all.map(a => (
              <li>
                <a
                  href={`/guias/${a.id}`}
                  class="block py-4 hover:bg-surface-raised px-2 -mx-2 rounded"
                >
                  <div class="font-semibold text-ink">{a.data.title}</div>
                  <p class="text-sm text-ink-muted mt-1">{a.data.description}</p>
                </a>
              </li>
            ))}
          </ul>
        </>
      )}
    </section>
  </Container>
</BaseLayout>
