---
import Container from '../components/layout/Container.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="Página no encontrada · 404 | factu.guide"
  description="La página que buscas no existe o fue movida. Vuelve al inicio o usa los enlaces a guías y herramientas."
>
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-50 via-white to-brand-50/30 py-20 md:py-28">
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(37,99,235,0.18)_1px,transparent_0)] [background-size:24px_24px] [mask-image:radial-gradient(ellipse_at_center,black,transparent_75%)]"
      aria-hidden="true"
    ></div>
    <Container>
      <div class="relative max-w-2xl mx-auto text-center">
        <p class="font-mono text-7xl md:text-8xl font-bold text-brand-700/30 mb-2">404</p>
        <h1 class="font-serif text-3xl md:text-4xl font-bold text-ink leading-tight mb-4">
          Esta página no existe (o ya no).
        </h1>
        <p class="text-lg text-ink-muted leading-relaxed mb-10">
          Puede que el enlace esté roto o la página haya sido movida.
          Aquí tienes formas rápidas de seguir.
        </p>

        <div class="grid gap-4 sm:grid-cols-2 max-w-xl mx-auto text-left">
          <a
            href="/guias"
            class="group block rounded-2xl border border-zinc-200 bg-white p-5 hover:shadow-xl hover:-translate-y-1 hover:border-brand-300 transition-all"
          >
            <div class="text-2xl mb-2">📚</div>
            <p class="font-serif font-bold text-ink">Guías</p>
            <p class="text-sm text-ink-muted mt-1">VeriFactu, IVA, IRPF, casos.</p>
            <span class="mt-3 inline-flex items-center gap-1 text-xs font-semibold text-brand-700 group-hover:gap-2 transition-all">
              Ver
              <span>→</span>
            </span>
          </a>
          <a
            href="/herramientas"
            class="group block rounded-2xl border border-zinc-200 bg-white p-5 hover:shadow-xl hover:-translate-y-1 hover:border-brand-300 transition-all"
          >
            <div class="text-2xl mb-2">🔎</div>
            <p class="font-serif font-bold text-ink">Herramientas</p>
            <p class="text-sm text-ink-muted mt-1">Validador NIF, calculadora IVA, gen XML.</p>
            <span class="mt-3 inline-flex items-center gap-1 text-xs font-semibold text-brand-700 group-hover:gap-2 transition-all">
              Ver
              <span>→</span>
            </span>
          </a>
        </div>

        <p class="mt-10 text-sm text-ink-subtle">
          ¿Crees que es un error?
          <a href="/contacto" class="text-brand-700 font-medium hover:underline">Avísanos</a>.
        </p>
      </div>
    </Container>
  </section>
</BaseLayout>
