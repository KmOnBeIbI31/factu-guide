---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Container from '../../components/layout/Container.astro';

const TOOLS = [
  {
    href: '/herramientas/validador-nif',
    title: 'Validador NIF / CIF / NIE',
    desc: 'Comprueba si un identificador es válido. Letra de control AEAT.',
  },
  {
    href: '/herramientas/calculadora-iva',
    title: 'Calculadora IVA + IRPF',
    desc: 'Desglose completo de factura. Formato es-ES.',
  },
  {
    href: '/herramientas/generador-xml-verifactu',
    title: 'Generador XML VeriFactu',
    desc: 'Demo educativo del registro VeriFactu con huella SHA-256.',
  },
];
---
<BaseLayout
  title="Herramientas free para autónomos | factu.guide"
  description="Validador NIF, calculadora IVA/IRPF y generador XML VeriFactu. Gratis, sin registro."
>
  <Container>
    <section class="py-12">
      <h1 class="text-4xl font-bold text-ink">Herramientas</h1>
      <p class="mt-3 text-lg text-ink-muted">Útiles, gratis y sin registro.</p>
      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {TOOLS.map(t => (
          <a
            href={t.href}
            class="block rounded-xl border border-zinc-200 bg-white p-5 shadow-card hover:border-brand-500 transition"
          >
            <h2 class="font-semibold text-ink">{t.title}</h2>
            <p class="mt-2 text-sm text-ink-muted">{t.desc}</p>
          </a>
        ))}
      </div>
    </section>
  </Container>
</BaseLayout>
