---
import Container from '../../components/layout/Container.astro';
import BaseLayout from '../../layouts/BaseLayout.astro';

const TOOLS = [
  {
    href: '/herramientas/validador-nif',
    title: 'Validador NIF / CIF / NIE',
    desc: 'Comprueba la letra de control AEAT en segundos. Detección automática de tipo (DNI, NIE, CIF) y de organización.',
    icon: '🔎',
    iconBg: 'bg-brand-100 text-brand-700',
  },
  {
    href: '/herramientas/calculadora-iva',
    title: 'Calculadora IVA + IRPF',
    desc: 'Desglose completo de factura con tipos vigentes 2026 (4%, 10%, 21%) y retenciones IRPF (7%, 15%, 19%).',
    icon: '🧮',
    iconBg: 'bg-amber-100 text-amber-700',
  },
  {
    href: '/herramientas/generador-xml-verifactu',
    title: 'Generador XML VeriFactu',
    desc: 'Construye un registro de alta canónico y calcula la huella SHA-256 en tu navegador. Demo educativo.',
    icon: '🧬',
    iconBg: 'bg-green-100 text-green-700',
  },
];
---
<BaseLayout
  title="Herramientas free para autónomos | factu.guide"
  description="Validador NIF, calculadora IVA/IRPF y generador XML VeriFactu. Gratis, sin registro, 100% en tu navegador."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-50 via-white to-brand-50/30 py-16 md:py-20">
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(37,99,235,0.18)_1px,transparent_0)] [background-size:24px_24px] [mask-image:radial-gradient(ellipse_at_center,black,transparent_75%)]"
      aria-hidden="true"
    ></div>
    <Container>
      <div class="relative max-w-3xl mx-auto text-center">
        <p class="text-xs uppercase tracking-[0.15em] text-brand-700 font-bold mb-3">
          Herramientas
        </p>
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-ink leading-[1.1] tracking-tight">
          Útiles, gratis y sin registro.
        </h1>
        <p class="mt-5 text-lg text-ink-muted leading-relaxed">
          Cálculo, validación y generación de XML en tu navegador. Tus datos
          nunca salen de tu equipo.
        </p>
      </div>
    </Container>
  </section>

  <!-- Tools grid -->
  <section class="py-16 md:py-20">
    <Container>
      <div class="grid gap-6 md:grid-cols-3">
        {TOOLS.map(t => (
          <a
            href={t.href}
            class="group block rounded-2xl border border-zinc-200 bg-white p-7 hover:shadow-xl hover:-translate-y-1 hover:border-brand-300 transition-all duration-200"
          >
            <div class={`h-12 w-12 rounded-xl ${t.iconBg} flex items-center justify-center text-2xl mb-5`}>
              {t.icon}
            </div>
            <h2 class="font-serif text-lg font-bold text-ink mb-2">{t.title}</h2>
            <p class="text-sm text-ink-muted leading-relaxed">{t.desc}</p>
            <span class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-brand-700 group-hover:gap-2 transition-all">
              Abrir herramienta
              <span>→</span>
            </span>
          </a>
        ))}
      </div>
    </Container>
  </section>
</BaseLayout>
