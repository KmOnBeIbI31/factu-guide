---
import { getEntry } from 'astro:content';
import Container from '../components/layout/Container.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const author = await getEntry('authors', 'adrian-sanchez');
if (!author) throw new Error('Author adrian-sanchez not found');
---
<BaseLayout
  title="Sobre factu.guide y su autor | factu.guide"
  description="factu.guide es un sitio independiente sobre VeriFactu y facturación electrónica, escrito por Adrián Sánchez, dev y creador de verifactu-mcp."
>
  <Container>
    <section class="py-12 max-w-2xl">
      <h1 class="text-4xl font-bold text-ink">Sobre factu.guide</h1>
      <p class="mt-4 text-lg text-ink-muted">
        factu.guide es un sitio independiente que publica guías y herramientas gratuitas sobre
        VeriFactu, IVA, IRPF y casos prácticos de facturación electrónica para autónomos y
        gestorías españolas.
      </p>
      <p class="mt-4 text-ink-muted">
        <strong>No es el sitio oficial de la AEAT.</strong> El sitio oficial es
        <a href="https://sede.agenciatributaria.gob.es" class="text-brand-600 hover:underline">
          sede.agenciatributaria.gob.es
        </a>.
        El contenido aquí es informativo y no constituye asesoramiento fiscal — consulta a un
        asesor antes de tomar decisiones.
      </p>

      <h2 class="mt-12 text-2xl font-bold text-ink">El autor</h2>
      <div class="mt-4 flex items-start gap-4 rounded-xl border border-zinc-200 bg-surface-raised p-5">
        <div class="h-16 w-16 rounded-full bg-brand-500 text-white flex items-center justify-center font-bold text-2xl flex-shrink-0">
          {author.data.name.charAt(0)}
        </div>
        <div class="text-sm">
          <div class="font-bold text-ink text-lg">{author.data.name}</div>
          <div class="text-ink-subtle text-xs uppercase tracking-wider mb-2">{author.data.role}</div>
          <p class="text-ink-muted">{author.data.bio}</p>
          <div class="mt-3 flex flex-wrap gap-3 text-xs">
            {author.data.sameAs.map(url => (
              <a href={url} class="text-brand-600 hover:underline" rel="me">
                {new URL(url).hostname.replace('www.', '')}
              </a>
            ))}
          </div>
        </div>
      </div>

      <h2 class="mt-12 text-2xl font-bold text-ink">Cómo está hecho</h2>
      <p class="mt-3 text-ink-muted">
        factu.guide está construido con Astro, MDX y Tailwind. Hosting en Cloudflare Pages.
        Sin trackers más allá de Google Analytics 4 y publicidad de Google AdSense, ambas
        gestionadas con consentimiento vía Funding Choices (CMP).
      </p>

      <h2 class="mt-12 text-2xl font-bold text-ink">Contacto</h2>
      <p class="mt-3 text-ink-muted">
        ¿Errata, sugerencia, propuesta de colaboración? Escríbeme en
        <a href="/contacto" class="text-brand-600 hover:underline">/contacto</a>.
      </p>
    </section>
  </Container>
</BaseLayout>
