---
import { getEntry } from 'astro:content';
import Container from '../components/layout/Container.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const author = await getEntry('authors', 'adrian-sanchez');
if (!author) throw new Error('Author adrian-sanchez not found');
---
<BaseLayout
  title="Sobre factu.guide | factu.guide"
  description="factu.guide es un sitio independiente sobre VeriFactu y facturación electrónica para autónomos y gestorías españolas."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-brand-50 via-white to-brand-50/30 py-16 md:py-20">
    <div
      class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(37,99,235,0.18)_1px,transparent_0)] [background-size:24px_24px] [mask-image:radial-gradient(ellipse_at_center,black,transparent_75%)]"
      aria-hidden="true"
    ></div>
    <Container>
      <div class="relative max-w-3xl mx-auto text-center">
        <p class="text-xs uppercase tracking-[0.15em] text-brand-700 font-bold mb-3">Sobre</p>
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-ink leading-[1.1] tracking-tight">
          Información clara sobre VeriFactu, sin ruido.
        </h1>
        <p class="mt-5 text-lg text-ink-muted leading-relaxed">
          Un sitio independiente con guías y herramientas gratuitas para
          autónomos y gestorías que se enfrentan a la facturación electrónica
          y la nueva normativa AEAT.
        </p>
      </div>
    </Container>
  </section>

  <Container>
    <div class="max-w-2xl mx-auto py-16 md:py-20 space-y-12">
      <section>
        <p class="text-xs uppercase tracking-[0.15em] text-brand-700 font-bold mb-3">
          Qué es factu.guide
        </p>
        <h2 class="font-serif text-2xl md:text-3xl font-bold text-ink mb-4">
          Un manual de campo, no asesoría
        </h2>
        <p class="text-ink-muted leading-relaxed">
          factu.guide publica explicaciones claras de VeriFactu, IVA, IRPF y
          casos prácticos por sector. No vende cursos, no recomienda software
          a cambio de comisión, y no pretende sustituir a un asesor fiscal.
          La meta es resolverte la duda concreta y, si quieres, llevarte de
          vuelta a la fuente oficial.
        </p>
      </section>

      <section>
        <p class="text-xs uppercase tracking-[0.15em] text-brand-700 font-bold mb-3">Independiente</p>
        <h2 class="font-serif text-2xl md:text-3xl font-bold text-ink mb-4">
          No es el sitio oficial de la AEAT
        </h2>
        <p class="text-ink-muted leading-relaxed">
          factu.guide no está afiliado a la Agencia Tributaria ni a ningún
          organismo público. El sitio oficial es
          <a href="https://sede.agenciatributaria.gob.es" class="text-brand-700 font-medium hover:underline">sede.agenciatributaria.gob.es</a>.
          El contenido aquí es informativo: ayuda a entender la normativa,
          pero no sustituye asesoramiento profesional.
        </p>
      </section>

      <section>
        <p class="text-xs uppercase tracking-[0.15em] text-brand-700 font-bold mb-3">Autor</p>
        <h2 class="font-serif text-2xl md:text-3xl font-bold text-ink mb-4">
          Quién escribe
        </h2>
        <div class="rounded-2xl border border-zinc-200 bg-white p-7 shadow-card flex items-start gap-5">
          <div class="h-16 w-16 rounded-full bg-gradient-to-br from-brand-500 to-brand-700 text-white flex items-center justify-center font-serif font-bold text-2xl flex-shrink-0">
            {author.data.name.charAt(0)}
          </div>
          <div class="text-sm min-w-0">
            <div class="font-serif font-bold text-ink text-lg">{author.data.name}</div>
            <div class="text-ink-subtle text-xs uppercase tracking-[0.15em] font-semibold mb-3">
              {author.data.role}
            </div>
            <p class="text-ink-muted leading-relaxed">{author.data.bio}</p>
            <div class="mt-4 flex flex-wrap gap-3 text-xs">
              {author.data.sameAs.map(url => (
                <a
                  href={url}
                  class="inline-flex items-center gap-1 rounded-full border border-zinc-200 px-3 py-1 text-ink-muted hover:border-brand-500 hover:text-brand-700 transition"
                  rel="me"
                >
                  {new URL(url).hostname.replace('www.', '')}
                  <span>→</span>
                </a>
              ))}
            </div>
          </div>
        </div>
      </section>

      <section>
        <p class="text-xs uppercase tracking-[0.15em] text-brand-700 font-bold mb-3">Contacto</p>
        <h2 class="font-serif text-2xl md:text-3xl font-bold text-ink mb-4">
          ¿Errata, sugerencia, colaboración?
        </h2>
        <p class="text-ink-muted leading-relaxed">
          Si encuentras algo incorrecto o tienes propuesta de mejora, escríbeme
          desde <a href="/contacto" class="text-brand-700 font-medium hover:underline">/contacto</a>.
          Respondo en 48-72h hábiles.
        </p>
      </section>
    </div>
  </Container>
</BaseLayout>
