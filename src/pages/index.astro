---
import McpHeroBanner from '../components/cta/McpHeroBanner.astro';
import Container from '../components/layout/Container.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout
  title="factu.guide — Cumple VeriFactu sin volverte loco"
  description="Guías, calculadoras y un MCP que emite facturas desde Claude. Para autónomos y gestorías españolas."
>
  <Container>
    <section class="py-16 text-center">
      <h1 class="text-4xl md:text-5xl font-bold text-ink leading-tight">
        Cumple VeriFactu sin volverte loco.
      </h1>
      <p class="mt-4 text-lg text-ink-muted">
        Guías, calculadoras y un MCP que emite facturas desde Claude.
      </p>
    </section>
  </Container>

  <McpHeroBanner />
</BaseLayout>
