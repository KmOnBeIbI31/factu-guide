---
type Variant = 'primary' | 'secondary' | 'ghost';
interface Props {
  variant?: Variant;
  href?: string;
  type?: 'button' | 'submit';
  class?: string;
}
const { variant = 'primary', href, type = 'button', class: cls = '' } = Astro.props;

const base = 'inline-flex items-center justify-center gap-2 px-4 py-2 rounded-md text-sm font-semibold transition focus:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-offset-2';
const variants: Record<Variant, string> = {
  primary:   'bg-brand-500 text-white hover:bg-brand-600',
  secondary: 'bg-surface-sunken text-ink hover:bg-surface-raised',
  ghost:     'text-ink hover:bg-surface-sunken',
};
const className = `${base} ${variants[variant]} ${cls}`.trim();
---
{href
  ? <a href={href} class={className}><slot /></a>
  : <button type={type} class={className}><slot /></button>
}
