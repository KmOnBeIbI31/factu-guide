---
type Tone = 'success' | 'danger' | 'warn' | 'neutral';
interface Props { tone?: Tone; }
const { tone = 'neutral' } = Astro.props;
const tones: Record<Tone, string> = {
  success: 'bg-green-100 text-green-800',
  danger:  'bg-red-100 text-red-800',
  warn:    'bg-amber-100 text-amber-800',
  neutral: 'bg-zinc-100 text-zinc-800',
};
---
<span class={`inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 text-xs font-semibold ${tones[tone]}`}>
  <slot />
</span>
