---
import type { HTMLAttributes } from 'astro/types';

interface Props {
  id: string;
  label: string;
  type?: HTMLAttributes<'input'>['type'];
  placeholder?: string;
  hint?: string;
  value?: string;
  name?: string;
}
const { id, label, type = 'text', placeholder, hint, value, name } = Astro.props;
---
<label for={id} class="block">
  <span class="block text-sm font-medium text-ink mb-1">{label}</span>
  <input
    id={id}
    name={name ?? id}
    type={type}
    placeholder={placeholder}
    value={value}
    class="block w-full rounded-md border border-zinc-300 px-3 py-2 text-sm focus:border-brand-500 focus:ring-1 focus:ring-brand-500"
  />
  {hint && <span class="mt-1 block text-xs text-ink-subtle">{hint}</span>}
</label>
