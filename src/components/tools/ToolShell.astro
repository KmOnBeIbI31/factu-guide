---
import Container from '../layout/Container.astro';

interface Props {
  title: string;
  subtitle: string;
}
const { title, subtitle } = Astro.props;
---
<!-- Hero -->
<section class="relative overflow-hidden bg-gradient-to-br from-brand-50 via-white to-brand-50/30 py-12 md:py-16">
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_1px_1px,rgba(37,99,235,0.18)_1px,transparent_0)] [background-size:24px_24px] [mask-image:radial-gradient(ellipse_at_center,black,transparent_75%)]"
    aria-hidden="true"
  ></div>
  <Container>
    <div class="relative max-w-3xl mx-auto text-center">
      <p class="text-xs uppercase tracking-[0.15em] text-brand-700 font-bold mb-3">Herramienta</p>
      <h1 class="font-serif text-3xl md:text-5xl font-bold text-ink leading-[1.1] tracking-tight">
        {title}
      </h1>
      <p class="mt-4 text-lg text-ink-muted leading-relaxed">{subtitle}</p>
    </div>
  </Container>
</section>

<!-- Tool body -->
<Container>
  <div class="max-w-3xl mx-auto py-12 md:py-16">
    <slot name="tool" />
  </div>
</Container>

<!-- Explainer content -->
<section class="bg-surface-raised py-12 md:py-16 border-t border-zinc-200">
  <Container>
    <div class="prose prose-zinc prose-lg max-w-3xl mx-auto
                prose-headings:font-serif prose-headings:text-ink prose-headings:tracking-tight
                prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4
                prose-h3:text-lg prose-h3:mt-8 prose-h3:mb-3
                prose-p:font-serif prose-p:leading-[1.75] prose-p:text-ink/90
                prose-strong:text-ink prose-strong:font-semibold
                prose-a:text-brand-700 prose-a:font-medium prose-a:no-underline hover:prose-a:underline">
      <slot name="content" />
    </div>
  </Container>
</section>

<section class="py-10">
  <Container>
    <div class="max-w-3xl mx-auto"><slot name="ad" /></div>
  </Container>
</section>
