---
const ga4Id = import.meta.env.PUBLIC_GA4_ID ?? '';
const adsenseId = import.meta.env.PUBLIC_ADSENSE_CLIENT ?? '';
// If AdSense is not active there is no CMP banner that can update consent,
// so analytics would be permanently denied. We default analytics to granted
// in that case (legitimate interest for first-party stats). When AdSense
// goes live, the Funding Choices CMP loads and takes over via consent
// updates from the user's explicit choice.
const analyticsDefault = adsenseId ? 'denied' : 'granted';
---
{ga4Id && (
  <>
    <script async src={`https://www.googletagmanager.com/gtag/js?id=${ga4Id}`} />
    <script
      set:html={`window.dataLayer = window.dataLayer || [];
function gtag(){dataLayer.push(arguments);}
window.gtag = gtag;

// Consent Mode v2 defaults. Funding Choices CMP (loaded only when AdSense is
// active) updates these via consent 'update' calls based on user choice.
gtag('consent', 'default', {
  ad_storage: 'denied',
  ad_user_data: 'denied',
  ad_personalization: 'denied',
  analytics_storage: '${analyticsDefault}',
  wait_for_update: 500
});

gtag('js', new Date());
gtag('config', '${ga4Id}', { anonymize_ip: true });`}
    />
  </>
)}
