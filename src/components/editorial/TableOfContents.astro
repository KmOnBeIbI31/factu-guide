---
interface Heading {
  depth: number;
  slug: string;
  text: string;
}
interface Props { headings: Heading[]; }
const { headings } = Astro.props;

const items = headings.filter(h => h.depth === 2 || h.depth === 3);
---
{items.length > 0 && (
  <nav aria-label="Índice del artículo" class="hidden lg:block sticky top-20 self-start">
    <div class="rounded-xl border border-zinc-200 bg-white p-5 shadow-card">
      <div class="text-[11px] uppercase tracking-[0.15em] text-brand-700 mb-4 font-sans font-bold">
        En esta guía
      </div>
      <ol class="space-y-2.5 text-sm font-sans border-l border-zinc-200">
        {items.map(h => (
          <li class={h.depth === 3 ? 'pl-6 ml-3 border-l border-transparent' : 'pl-4 -ml-px border-l-2 border-transparent hover:border-brand-500 transition-colors'}>
            <a
              href={`#${h.slug}`}
              class={`block py-0.5 leading-snug transition-colors ${h.depth === 3 ? 'text-ink-subtle text-[13px] hover:text-brand-700' : 'text-ink-muted font-medium hover:text-brand-700'}`}
            >
              {h.text}
            </a>
          </li>
        ))}
      </ol>
    </div>
  </nav>
)}
