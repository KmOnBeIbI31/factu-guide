---
import { getEntry } from 'astro:content';
interface Props { authorId: string; }
const { authorId } = Astro.props;
const author = await getEntry('authors', authorId);
if (!author) throw new Error(`Author not found: ${authorId}`);
---
<aside class="my-8 flex items-start gap-4 rounded-xl border border-zinc-200 bg-surface-raised p-4">
  <div class="h-12 w-12 rounded-full bg-brand-500 text-white flex items-center justify-center font-bold flex-shrink-0">
    {author.data.name.charAt(0)}
  </div>
  <div class="text-sm font-sans">
    <div class="font-semibold text-ink">{author.data.name}</div>
    <div class="text-ink-subtle text-xs uppercase tracking-wider mb-1">{author.data.role}</div>
    <p class="text-ink-muted">{author.data.bio}</p>
    <div class="mt-2 flex gap-3 text-xs">
      {author.data.sameAs.map(url => (
        <a href={url} class="text-brand-600 hover:underline" rel="me">
          {new URL(url).hostname.replace('www.', '')}
        </a>
      ))}
    </div>
  </div>
</aside>
