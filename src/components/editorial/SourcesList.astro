---
interface Props {
  sources?: Array<{ label: string; url: string }>;
  factCheckedAt?: Date;
}
const { sources, factCheckedAt } = Astro.props;
---
{sources && sources.length > 0 && (
  <section class="mt-10 rounded-xl border border-zinc-200 bg-surface-raised p-5 font-sans text-sm">
    <h3 class="font-semibold text-ink mb-3">Fuentes</h3>
    <ul class="space-y-2">
      {sources.map(s => (
        <li>
          <a href={s.url} class="text-brand-600 hover:underline" rel="noopener" target="_blank">
            {s.label}
          </a>
        </li>
      ))}
    </ul>
    {factCheckedAt && (
      <p class="mt-3 text-xs text-ink-subtle">
        Verificado el {factCheckedAt.toLocaleDateString('es-ES', { year: 'numeric', month: 'long', day: 'numeric' })}.
      </p>
    )}
  </section>
)}
