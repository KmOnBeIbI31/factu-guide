---
import { type CollectionEntry, getCollection } from 'astro:content';

interface Props { current: CollectionEntry<'blog'>; }
const { current } = Astro.props;

const related = (await getCollection('blog', (e) => !e.data.draft && e.id !== current.id))
  .filter((e) => e.data.pillar === current.data.pillar)
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime())
  .slice(0, 3);
---
{related.length > 0 && (
  <section class="mt-12 font-sans">
    <h3 class="text-xl font-bold text-ink mb-4">Relacionado</h3>
    <ul class="grid gap-3 sm:grid-cols-3">
      {related.map(a => (
        <li>
          <a
            href={`/guias/${a.id}`}
            class="block rounded-lg border border-zinc-200 bg-white p-4 hover:border-brand-500 transition h-full"
          >
            <div class="text-sm font-semibold text-ink">{a.data.title}</div>
            <div class="mt-1 text-xs text-ink-subtle">{a.data.readingTime} min</div>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}
