---
import Container from './Container.astro';
const NAV = [
  { href: '/guias',         label: 'Guías' },
  { href: '/herramientas',  label: 'Herramientas' },
  { href: '/mcp',           label: 'MCP', highlight: true },
  { href: '/sobre',         label: 'Sobre' },
];
const path = Astro.url.pathname;
---
<header class="border-b border-zinc-200 bg-white sticky top-0 z-40">
  <Container>
    <div class="flex h-14 items-center justify-between">
      <a href="/" class="flex items-center gap-2 font-bold text-ink">
        <span class="inline-block h-6 w-6 rounded-md bg-brand-500"></span>
        factu.guide
      </a>
      <nav aria-label="Principal" class="flex items-center gap-1 md:gap-2">
        {NAV.map(item => (
          <a
            href={item.href}
            class:list={[
              'rounded-md px-3 py-1.5 text-sm font-medium transition',
              item.highlight
                ? 'bg-ink text-white hover:bg-ink/90'
                : path.startsWith(item.href)
                  ? 'text-brand-700'
                  : 'text-ink-muted hover:text-ink',
            ]}
          >{item.label}</a>
        ))}
      </nav>
    </div>
  </Container>
</header>
