    "@tailwindcss/vite": "^4.3.0",
    "astro": "^6.3.7",
    "preact": "^10.29.2",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.11.3",
